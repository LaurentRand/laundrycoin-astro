---
import Icon from "./icon.astro";

const reviews = [
  {
    name: "James Milton",
    text: "Sangat bersih, cepat, dan praktis! Harga sangat terjangkau untuk mahasiswa.",
  },
  {
    name: "James Milton",
    text: "Pelayanan ramah, tempat bersih, mesin terawat dan bersih.",
  },
  {
    name: "James Milton",
    text: "Pelayanan ramah, tempat bersih, mesin terawat dan bersih.",
  },
  {
    name: "James Milton",
    text: "Antre cepat, mesin selalu ready, dan tempatnya nyaman buat nunggu.",
  },
];
---

<section id="review" class="overflow-hidden bg-surface py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <h2 class="section-heading mx-auto block text-center">Review Pelanggan</h2>

    <div class="relative mt-16">
      <!-- Track: px besar sengaja dipakai supaya card kiri/kanan "mengintip" (peek effect) -->
      <div id="review-track" class="flex cursor-grab snap-x snap-mandatory gap-6 overflow-x-auto scroll-smooth px-[6%] pb-2 [-ms-overflow-style:none] [scrollbar-width:none] sm:px-[10%] [&::-webkit-scrollbar]:hidden">
        {
          reviews.map((r) => (
            <article data-review-card class="review-card w-[78%] shrink-0 snap-center rounded-3xl bg-cyan-50 p-8 text-center shadow-sm shadow-slate-200 transition-all duration-300 ease-out sm:w-[55%] lg:w-[32%]">
              <div class="mx-auto mb-4 h-16 w-16 rounded-full bg-white shadow-inner shadow-slate-200" />

              <p class="font-display font-bold text-navy-950">{r.name}</p>

              <div class="mt-2 mb-4 flex justify-center gap-1 text-amber-400">
                {Array.from({ length: 5 }).map(() => (
                  <Icon name="star" class="h-4 w-4 fill-current" />
                ))}
              </div>

              <p class="text-sm leading-relaxed text-navy-950/70">{r.text}</p>

              <p class="mt-6 font-display font-bold tracking-tight text-cyan-700">Coin Wash+</p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  /* Card yang sedang berada di tengah viewport ditonjolkan (mirip desain) */
  .review-card.is-active {
    background-color: rgb(207 250 254 / 0.8); /* cyan-100/80 */
    transform: scale(1.03);
    box-shadow: 0 10px 25px -5px rgb(0 0 0 / 0.08);
  }
</style>

<script>
  const track = document.getElementById("review-track");
  const cards = Array.from(document.querySelectorAll<HTMLElement>("[data-review-card]"));

  // Tanpa tombol, geser via drag mouse (desktop) tetap didukung selain swipe/trackpad.
  if (track) {
    let isDown = false;
    let startX = 0;
    let scrollLeftStart = 0;

    track.addEventListener("pointerdown", (e) => {
      isDown = true;
      track.classList.add("cursor-grabbing");
      startX = e.clientX;
      scrollLeftStart = track.scrollLeft;
    });

    track.addEventListener("pointermove", (e) => {
      if (!isDown) return;
      e.preventDefault();
      const delta = e.clientX - startX;
      track.scrollLeft = scrollLeftStart - delta;
    });

    const endDrag = () => {
      isDown = false;
      track.classList.remove("cursor-grabbing");
    };

    track.addEventListener("pointerup", endDrag);
    track.addEventListener("pointerleave", endDrag);
  }

  // Highlight card yang paling terlihat di tengah track (efek "aktif" saat scroll)
  if (track && cards.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          entry.target.classList.toggle("is-active", entry.intersectionRatio > 0.6);
        });
      },
      {
        root: track,
        threshold: [0, 0.6, 1],
      },
    );

    cards.forEach((card) => observer.observe(card));
  }
</script>
