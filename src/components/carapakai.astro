---
import Icon from "./icon.astro";

const steps = [
  {
    icon: "map-pin",
    title: "Datang ke Lokasi",
    desc: "Temukan lokasi CoinWash+ terdekat dari Anda.",
  },
  {
    icon: "washer",
    title: "Pilih Mesin Cuci",
    desc: "Pilih mesin sesuai kebutuhan Anda.",
  },
  {
    icon: "coins",
    title: "Bayar",
    desc: "Masukkan koin sesuai tarif yang tertera.",
  },
  {
    icon: "hourglass",
    title: "Tunggu Sampai Selesai",
    desc: "Mesin bekerja otomatis, tinggal tunggu selesai.",
  },
] as const;
---

<section id="cara-pakai" class="bg-surface py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <h1 class="section-heading mx-auto block text-center font-display font-bold text-4xl">Cara Pakai</h1>

    <div class="relative mt-24 grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- connecting dashed line, desktop only -->
      <div class="absolute left-0 right-0 top-5 hidden border-t-2 border-dashed border-slate-300 lg:block" aria-hidden="true"></div>

      {
        steps.map((step, i) => (
          <div class="relative flex flex-col items-center rounded-2xl bg-white px-6 pb-8 pt-11 mb-6 text-center shadow-sm shadow-slate-200">
            <span class="absolute -top-5 flex h-10 w-10 items-center justify-center rounded-full bg-navy-950 font-display text-sm font-bold text-white">{i + 1}</span>
            <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-cyan-500/10 text-cyan-600">
              <Icon name={step.icon} class="h-8 w-8" />
            </div>
            <h3 class="font-display text-lg font-bold text-navy-950">{step.title}</h3>
            <p class="mt-2 text-sm text-muted">{step.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
