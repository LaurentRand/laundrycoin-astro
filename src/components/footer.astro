---
import Icon from "./icon.astro";

const quickLinks = [
  { label: "Beranda", href: "#beranda" },
  { label: "Cara Pakai", href: "#cara-pakai" },
  { label: "Harga", href: "#harga" },
  { label: "Fasilitas", href: "#fasilitas" },
  { label: "Review", href: "#review" },
];
---

<footer class="bg-navy-950 pt-16 text-slate-300">
  <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 px-6 pb-12 sm:grid-cols-2 lg:grid-cols-4 lg:px-10">
    <div>
      <p class="font-display text-xl font-extrabold text-white">
        CoinWash<span class="text-cyan-400">+</span>
      </p>
      <p class="mt-3 text-sm text-slate-400">Laundry koin modern dengan mesin berkualitas, proses cepat, dan hasil maksimal.</p>
      <div class="mt-5 flex gap-3">
        <a href="https://wa.me/6281234567890" aria-label="WhatsApp" class="flex h-9 w-9 items-center justify-center rounded-full border border-navy-border text-slate-300 transition hover:border-cyan-400 hover:text-cyan-400">
          <Icon name="whatsapp" class="h-4 w-4" />
        </a>
        <a href="#" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-full border border-navy-border text-slate-300 transition hover:border-cyan-400 hover:text-cyan-400">
          <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.6"></rect>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6"></circle>
            <circle cx="17.2" cy="6.8" r="1" fill="currentColor"></circle>
          </svg>
        </a>
        <a href="#" aria-label="Lokasi" class="flex h-9 w-9 items-center justify-center rounded-full border border-navy-border text-slate-300 transition hover:border-cyan-400 hover:text-cyan-400">
          <Icon name="map-pin" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <div>
      <h4 class="font-display text-sm font-bold text-white">Alamat</h4>
      <p class="mt-3 text-sm text-slate-400">Jl. Puri Janggani Indah Blok G No. 58, Kelurahan Belimbing, Kecamatan Samarinda, Jakarta Pusat</p>
    </div>

    <div>
      <h4 class="font-display text-sm font-bold text-white">Jam Operasional</h4>
      <p class="mt-3 flex items-start gap-2 text-sm text-slate-400">
        <Icon name="calendar" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-400" />
        <span>Setiap Hari<br />07.00 – 22.00 WIB</span>
      </p>
    </div>

    <div>
      <h4 class="font-display text-sm font-bold text-white">Tautan Cepat</h4>
      <ul class="mt-3 space-y-2 text-sm">
        {
          quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-slate-400 transition hover:text-cyan-400">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="border-t border-navy-border py-5 text-center text-xs text-slate-500">© 2026 CoinWash+. All rights reserved.</div>
</footer>
