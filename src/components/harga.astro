---
import Icon from "./icon.astro";
---

<section id="harga" class="bg-navy-950 py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <h1 class="section-heading mx-auto block font-display font-bold text-4xl text-center text-white after:bg-cyan-500">Harga</h1>

    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-3">
      <!-- Cuci Saja -->
      <div class="relative rounded-2xl border border-navy-border bg-navy-900 p-8 text-center">
        <span class="absolute -top-4 left-1/2 flex -translate-x-1/2 items-center gap-1.5 rounded-full bg-cyan-500 px-4 py-1.5 text-xs font-semibold text-navy-950">
          <Icon name="sparkles" class="h-3.5 w-3.5" />
          Paling Favorit
        </span>
        <div class="mx-auto mb-5 mt-4 flex h-16 w-16 items-center justify-center rounded-full border border-navy-border text-white">
          <Icon name="washer" class="h-8 w-8" />
        </div>
        <h3 class="font-display text-xl font-bold text-white">Cuci Saja</h3>
        <p class="mt-2 text-sm text-slate-300">Mesin Kapasitas 8 kg</p>
        <p class="mt-5 border-t border-navy-border pt-5 font-display text-2xl font-extrabold text-cyan-400">
          <span class="align-top text-base">Rp</span> 15.000
          <span class="text-sm font-medium text-slate-300"> / 1x Cuci</span>
        </p>
        <a href="https://wa.me/6281234567890" class="mt-6 inline-block w-full rounded-full border border-cyan-400/70 py-3 text-sm font-semibold text-cyan-300 transition hover:bg-cyan-400/10"> Pilih Mesin </a>
      </div>

      <!-- Kering Saja -->
      <div class="rounded-2xl border border-navy-border bg-navy-900 p-8 text-center">
        <div class="mx-auto mb-5 mt-4 flex h-16 w-16 items-center justify-center rounded-full border border-navy-border text-white">
          <Icon name="dryer" class="h-8 w-8" />
        </div>
        <h3 class="font-display text-xl font-bold text-white">Kering Saja</h3>
        <p class="mt-2 text-sm text-slate-300">Mesin Kapasitas 8 kg</p>
        <p class="mt-5 border-t border-navy-border pt-5 font-display text-2xl font-extrabold text-cyan-400">
          <span class="align-top text-base">Rp</span> 15.000
          <span class="text-sm font-medium text-slate-300"> / 1x Cuci</span>
        </p>
        <a href="https://wa.me/6281234567890" class="mt-6 inline-block w-full rounded-full border border-cyan-400/70 py-3 text-sm font-semibold text-cyan-300 transition hover:bg-cyan-400/10"> Pilih Mesin </a>
      </div>

      <!-- Setrika Uap -->
      <div class="rounded-2xl border border-navy-border bg-navy-900 p-8 text-center">
        <div class="mx-auto mb-5 mt-4 flex h-16 w-16 items-center justify-center rounded-full border border-navy-border text-white">
          <Icon name="iron" class="h-8 w-8" />
        </div>
        <h3 class="font-display text-xl font-bold text-white">Setrika Uap</h3>

        <div class="mt-5 space-y-3 border-t border-navy-border pt-5">
          <p class="flex items-center justify-between text-sm">
            <span class="text-slate-300">Mesin 10 Liter</span>
            <span class="font-display font-bold text-cyan-400">Rp 10.000</span>
          </p>
          <p class="flex items-center justify-between text-sm">
            <span class="text-slate-300">Mesin 15 Liter</span>
            <span class="font-display font-bold text-cyan-400">Rp 12.000</span>
          </p>
        </div>

        <a href="https://wa.me/6281234567890" class="mt-6 inline-block w-full rounded-full border border-cyan-400/70 py-3 text-sm font-semibold text-cyan-300 transition hover:bg-cyan-400/10"> Pilih Mesin </a>
      </div>
    </div>
  </div>
</section>
