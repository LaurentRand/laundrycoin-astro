---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const { title = "CoinWash+ — Laundry Koin Modern", description = "Laundry koin modern dengan mesin berkualitas, proses cepat, dan hasil cuci bersih maksimal." } = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Outfit:wght@100..900&display=swap" rel="stylesheet" />
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
